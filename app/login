"use client";

import { supabase } from "@/lib/supabase";

export default function Login() {
  const login = async () => {
    await supabase.auth.signInWithOAuth({
      provider: "google",
    });
  };

  return (
    <div className="p-6">
      <button className="btn w-full" onClick={login}>
        Login with Google
      </button>
    </div>
  );
}
